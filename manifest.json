{
  "manifest_version": 3,
  "name": "JobFit AI",
  "version": "1.0.0",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["src/content-script.ts"]
    }
  ]
}
